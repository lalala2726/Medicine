<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.zhangchuangla.medicine.admin.mapper.MallProductMapper">

    <resultMap id="BaseResultMap" type="cn.zhangchuangla.medicine.model.entity.MallProduct">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="categoryId" column="category_id"/>
        <result property="unit" column="unit"/>
        <result property="price" column="price"/>
        <result property="salesVolume" column="sales_volume"/>
        <result property="stock" column="stock"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="deliveryType" column="delivery_type"/>
        <result property="version" column="version"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
    </resultMap>

    <resultMap id="MallProductDtoMap" type="cn.zhangchuangla.medicine.model.dto.MallProductDetailDto">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="categoryId" column="category_id"/>
        <result property="unit" column="unit"/>
        <result property="price" column="price"/>
        <result property="salesVolume" column="sales_volume"/>
        <result property="stock" column="stock"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="deliveryType" column="delivery_type"/>
        <result property="version" column="version"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="categoryName" column="category_name"/>
        <collection property="images" ofType="java.lang.String">
            <result column="image_url"/>
        </collection>
    </resultMap>

    <sql id="Base_Column_List">
        id,name,category_id,unit,price,sales_volume,
        stock,sort,status,delivery_type,version,
        create_time,update_time,
        create_by,update_by
    </sql>
    <select id="listMallProduct" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM mall_product
        <where>
            <if test="request.id != null">
                AND id = #{request.id}
            </if>
            <if test="request.name != null and request.name != ''">
                AND name LIKE CONCAT('%', #{request.name}, '%')
            </if>
            <if test="request.categoryId != null">
                AND category_id = #{request.categoryId}
            </if>
            <if test="request.status != null">
                AND status = #{request.status}
            </if>
            <if test="request.minPrice != null">
                AND price >= #{request.minPrice}
            </if>
            <if test="request.maxPrice != null">
                AND price &lt;= #{request.maxPrice}
            </if>
        </where>
        ORDER BY sort ASC, create_time DESC
    </select>

    <!-- 查询商品列表（包含分类名称） -->
    <select id="listMallProductWithCategory" resultMap="MallProductDtoMap">
        SELECT
        p.id,
        p.name,
        p.category_id,
        p.unit,
        p.price,
        p.sales_volume,
        p.stock,
        p.sort,
        p.status,
        p.delivery_type,
        p.version,
        p.create_time,
        p.update_time,
        p.create_by,
        p.update_by,
        c.name AS category_name,
        (
        SELECT i.image_url
        FROM mall_product_image i
        WHERE i.product_id = p.id
        ORDER BY i.sort , i.id
        LIMIT 1
        ) AS image_url
        FROM mall_product p
        LEFT JOIN mall_category c ON p.category_id = c.id
        <where>
            <if test="request.id != null">
                AND p.id = #{request.id}
            </if>
            <if test="request.name != null and request.name != ''">
                AND p.name LIKE CONCAT('%', #{request.name}, '%')
            </if>
            <if test="request.categoryId != null">
                AND p.category_id = #{request.categoryId}
            </if>
            <if test="request.status != null">
                AND p.status = #{request.status}
            </if>
            <if test="request.minPrice != null">
                AND p.price >= #{request.minPrice}
            </if>
            <if test="request.maxPrice != null">
                AND p.price &lt;= #{request.maxPrice}
            </if>
        </where>
        ORDER BY p.sort , p.create_time DESC
    </select>

    <select id="getMallProductDetailById" resultMap="MallProductDtoMap">
        SELECT p.id,
               p.name,
               p.category_id,
               p.unit,
               p.price,
               p.sales_volume,
               p.stock,
               p.sort,
               p.status,
               p.delivery_type,
               p.version,
               p.create_time,
               p.update_time,
               p.create_by,
               p.update_by,
               c.name AS category_name,
               i.image_url AS image_url
        FROM mall_product p
                 LEFT JOIN mall_category c ON p.category_id = c.id
                 LEFT JOIN mall_product_image i ON i.product_id = p.id
        WHERE p.id = #{id}
        ORDER BY i.sort, i.id
    </select>
</mapper>
