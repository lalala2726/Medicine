<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.zhangchuangla.medicine.admin.mapper.MallProductMapper">

    <resultMap id="BaseResultMap" type="cn.zhangchuangla.medicine.model.entity.MallProduct">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="categoryId" column="category_id"/>
        <result property="unit" column="unit"/>
        <result property="price" column="price"/>
        <result property="salesVolume" column="sales_volume"/>
        <result property="stock" column="stock"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="deliveryType" column="delivery_type"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
    </resultMap>

    <resultMap id="MallProductDtoMap" type="cn.zhangchuangla.medicine.model.dto.MallProductDto">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="categoryId" column="category_id"/>
        <result property="unit" column="unit"/>
        <result property="price" column="price"/>
        <result property="salesVolume" column="sales_volume"/>
        <result property="stock" column="stock"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="deliveryType" column="delivery_type"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="categoryName" column="category_name"/>
        <result property="image" column="image_url"/>
    </resultMap>

    <resultMap id="MallProductDetailDtoMap" type="cn.zhangchuangla.medicine.model.dto.MallProductDetailDto">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="categoryId" column="category_id"/>
        <result property="unit" column="unit"/>
        <result property="price" column="price"/>
        <result property="salesVolume" column="sales_volume"/>
        <result property="stock" column="stock"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="deliveryType" column="delivery_type"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="image" column="main_image_url"/>
        <collection property="images" ofType="java.lang.String" notNullColumn="image_url">
            <result column="image_url"/>
        </collection>
    </resultMap>

    <sql id="Base_Column_List">
        id,name,category_id,unit,price,sales_volume,
        stock,sort,status,delivery_type,shipping_id,
        create_time,update_time,
        create_by,update_by
    </sql>
    <select id="listMallProduct" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM mall_product
        <where>
            <if test="request.id != null">
                AND id = #{request.id}
            </if>
            <if test="request.name != null and request.name != ''">
                AND name LIKE CONCAT('%', #{request.name}, '%')
            </if>
            <if test="request.categoryId != null">
                AND category_id = #{request.categoryId}
            </if>
            <if test="request.status != null">
                AND status = #{request.status}
            </if>
            <if test="request.minPrice != null">
                AND price >= #{request.minPrice}
            </if>
            <if test="request.maxPrice != null">
                AND price &lt;= #{request.maxPrice}
            </if>
        </where>
        ORDER BY sort ASC, create_time DESC
    </select>

    <!-- 查询商品列表（包含分类名称） -->
    <select id="listMallProductWithCategory" resultMap="MallProductDtoMap">
        SELECT
        p.id,
        p.name,
        p.category_id,
        p.unit,
        p.price,
        p.sales_volume,
        p.stock,
        p.sort,
        p.status,
        p.delivery_type,
        p.shipping_id,
        p.create_time,
        p.update_time,
        p.create_by,
        p.update_by,
        c.name AS category_name,
        (
        SELECT i.image_url
        FROM mall_product_image i
        WHERE i.product_id = p.id
        ORDER BY i.sort , i.id
        LIMIT 1
        ) AS image_url
        FROM mall_product p
        LEFT JOIN mall_category c ON p.category_id = c.id
        <where>
            <if test="request.id != null">
                AND p.id = #{request.id}
            </if>
            <if test="request.name != null and request.name != ''">
                AND p.name LIKE CONCAT('%', #{request.name}, '%')
            </if>
            <if test="request.categoryId != null">
                AND p.category_id = #{request.categoryId}
            </if>
            <if test="request.status != null">
                AND p.status = #{request.status}
            </if>
            <if test="request.minPrice != null">
                AND p.price >= #{request.minPrice}
            </if>
            <if test="request.maxPrice != null">
                AND p.price &lt;= #{request.maxPrice}
            </if>
        </where>
        ORDER BY p.sort ASC, p.create_time DESC
    </select>

    <select id="getMallProductDetailById" resultMap="MallProductDetailDtoMap">
        SELECT product.id,
               product.name,
               product.category_id,
               product.unit,
               product.price,
               product.sales_volume,
               product.stock,
               product.sort,
               product.status,
               product.delivery_type,
               product.shipping_id,
               product.create_time,
               product.update_time,
               product.create_by,
               product.update_by,
               main_image.image_url   AS main_image_url,
               detail_image.image_url AS image_url
        FROM mall_product product
                 LEFT JOIN mall_product_image main_image
                           ON main_image.product_id = product.id
                               AND main_image.sort = 0
                 LEFT JOIN mall_product_image detail_image
                           ON detail_image.product_id = product.id
        WHERE product.id = #{id}
        ORDER BY detail_image.sort, detail_image.id
    </select>
</mapper>
