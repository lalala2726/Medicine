<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.zhangchuangla.medicine.admin.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="cn.zhangchuangla.medicine.model.entity.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="nickname" column="nickname"/>
        <result property="avatar" column="avatar"/>
        <result property="status" column="status"/>
        <result property="realName" column="real_name"/>
        <result property="idCard" column="id_card"/>
        <result property="lastLoginTime" column="last_login_time"/>
        <result property="lastLoginIp" column="last_login_ip"/>
        <result property="lastLoginLocation" column="last_login_location"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="deleteTime" column="delete_time"/>
        <result property="isDelete" column="is_delete"/>
    </resultMap>

    <sql id="Base_Column_List">
        u.id, u.username, u.password, u.nickname, u.avatar, u.status, u.real_name, u.id_card,
        u.last_login_time, u.last_login_ip, u.last_login_location, u.create_time,
        u.update_time, u.create_by, u.update_by, u.delete_time, u.is_delete
    </sql>

    <select id="listUser" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM user u
        <where>
            u.is_delete = 0
            <if test="request.id != null">
                AND u.id = #{request.id}
            </if>
            <if test="request.username != null and request.username != ''">
                AND u.username LIKE CONCAT('%', #{request.username}, '%')
            </if>
            <if test="request.nickname != null and request.nickname != ''">
                AND u.nickname LIKE CONCAT('%', #{request.nickname}, '%')
            </if>
            <if test="request.avatar != null and request.avatar != ''">
                AND u.avatar = #{request.avatar}
            </if>
            <if test="request.roles != null and request.roles != ''">
                AND EXISTS (
                SELECT 1
                FROM user_role ur2
                JOIN role r2 ON ur2.role_id = r2.id
                WHERE ur2.user_id = u.id
                AND r2.role_code LIKE CONCAT('%', #{request.roles}, '%')
                )
            </if>
            <if test="request.status != null">
                AND u.status = #{request.status}
            </if>
            <if test="request.createBy != null and request.createBy != ''">
                AND u.create_by = #{request.createBy}
            </if>
        </where>
        ORDER BY u.create_time DESC
    </select>
    <resultMap id="UserOrderStatisticsMap" type="cn.zhangchuangla.medicine.admin.model.dto.UserOrderStatistics">
        <result property="totalOrderCount" column="total_order_count"/>
        <result property="totalConsumption" column="total_consumption"/>
    </resultMap>

    <select id="getOrderStatisticsByUserId"
            resultMap="UserOrderStatisticsMap">
        SELECT COUNT(1)                     AS total_order_count,
               COALESCE(SUM(pay_amount), 0) AS total_consumption
        FROM mall_order
        WHERE (is_deleted IS NULL OR is_deleted = 0)
          AND user_id = #{userId}
    </select>
</mapper>
