<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.zhangchuangla.medicine.admin.mapper.KbBaseMapper">

    <resultMap id="BaseResultMap" type="cn.zhangchuangla.medicine.model.entity.KbBase">
        <id property="id" column="id"/>
        <result property="knowledgeName" column="knowledge_name"/>
        <result property="displayName" column="display_name"/>
        <result property="cover" column="cover"/>
        <result property="description" column="description"/>
        <result property="embeddingModel" column="embedding_model"/>
        <result property="embeddingDim" column="embedding_dim"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,knowledge_name,display_name,cover,description,embedding_model,
        embedding_dim,status,create_by,update_by,created_at,updated_at
    </sql>

    <select id="listKnowledgeBase" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM kb_base kb
        <where>
            <if test="request.knowledgeName != null and request.knowledgeName != ''">
                AND kb.knowledge_name LIKE CONCAT('%', #{request.knowledgeName}, '%')
            </if>
            <if test="request.displayName != null and request.displayName != ''">
                AND kb.display_name LIKE CONCAT('%', #{request.displayName}, '%')
            </if>
            <if test="request.description != null and request.description != ''">
                AND kb.description LIKE CONCAT('%', #{request.description}, '%')
            </if>
            <if test="request.embeddingModel != null and request.embeddingModel != ''">
                AND kb.embedding_model LIKE CONCAT('%', #{request.embeddingModel}, '%')
            </if>
            <if test="request.embeddingDim != null">
                AND kb.embedding_dim = #{request.embeddingDim}
            </if>
            <if test="request.status != null">
                AND kb.status = #{request.status}
            </if>
        </where>
        ORDER BY kb.created_at DESC, kb.id DESC
    </select>
</mapper>
