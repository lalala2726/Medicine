<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.zhangchuangla.medicine.admin.mapper.KbDocumentMapper">

    <resultMap id="BaseResultMap" type="cn.zhangchuangla.medicine.model.entity.KbDocument">
        <id property="id" column="id"/>
        <result property="knowledgeBaseId" column="knowledge_base_id"/>
        <result property="fileName" column="file_name"/>
        <result property="fileUrl" column="file_url"/>
        <result property="fileType" column="file_type"/>
        <result property="chunkMode" column="chunk_mode"/>
        <result property="chunkSize" column="chunk_size"/>
        <result property="chunkOverlap" column="chunk_overlap"/>
        <result property="stage" column="stage"/>
        <result property="lastError" column="last_error"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,knowledge_base_id,file_name,file_url,
        file_type,chunk_mode,chunk_size,chunk_overlap,stage,last_error,create_by,
        update_by,created_at,updated_at
    </sql>

    <select id="listDocument" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM kb_document
        <where>
            knowledge_base_id = #{knowledgeBaseId}
            <if test="request.fileName != null and request.fileName != ''">
                AND file_name LIKE CONCAT('%', TRIM(#{request.fileName}), '%')
            </if>
            <if test="request.fileType != null and request.fileType != ''">
                AND LOWER(file_type) = LOWER(REPLACE(TRIM(#{request.fileType}), '.', ''))
            </if>
        </where>
        ORDER BY created_at DESC, id DESC
    </select>
</mapper>
