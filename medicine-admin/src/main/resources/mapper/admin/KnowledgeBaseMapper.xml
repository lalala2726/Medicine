<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.zhangchuangla.medicine.admin.mapper.KnowledgeBaseMapper">

    <resultMap id="BaseResultMap" type="cn.zhangchuangla.medicine.model.entity.KnowledgeBase">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="cover" column="cover"/>
        <result property="description" column="description"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,name,cover,description,create_time,update_time,create_by,update_by
    </sql>

    <select id="selectPageWithStats" resultType="cn.zhangchuangla.medicine.admin.model.dto.KnowledgeBaseStatsDto">
        SELECT
            kb.id,
            kb.name,
            kb.cover,
            kb.description,
            kb.create_time AS createTime,
            kb.update_time AS updateTime,
            kb.create_by AS createBy,
            kb.update_by AS updateBy,
            COALESCE(doc.file_count, 0) AS fileCount,
            COALESCE(doc.slice_count, 0) AS sliceCount
        FROM knowledge_base kb
        LEFT JOIN (
            SELECT
        kb_id,
        COUNT(*) AS file_count,
        COALESCE(SUM(chunk_count), 0) AS slice_count
        FROM kb_document
        GROUP BY kb_id
        ) doc ON kb.id = doc.kb_id
        <where>
            <if test="request.name != null and request.name != ''">
                AND kb.name LIKE CONCAT('%', #{request.name}, '%')
            </if>
            <if test="request.description != null and request.description != ''">
                AND kb.description LIKE CONCAT('%', #{request.description}, '%')
            </if>
        </where>
        ORDER BY kb.create_time DESC
    </select>
</mapper>
