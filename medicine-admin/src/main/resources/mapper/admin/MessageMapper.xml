<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.zhangchuangla.medicine.admin.mapper.MessageMapper">

    <resultMap id="BaseResultMap" type="cn.zhangchuangla.medicine.model.entity.Message">
        <id property="id" column="id"/>
