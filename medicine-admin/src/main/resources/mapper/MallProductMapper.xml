<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.zhangchuangla.medicine.mapper.MallProductMapper">

    <resultMap id="BaseResultMap" type="cn.zhangchuangla.medicine.common.core.model.entity.MallProduct">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="categoryId" column="category_id"/>
        <result property="unit" column="unit"/>
        <result property="price" column="price"/>
        <result property="salesVolume" column="sales_volume"/>
        <result property="stock" column="stock"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="deliveryType" column="delivery_type"/>
        <result property="shippingId" column="shipping_id"/>
        <result property="bindType" column="bind_type"/>
        <result property="medicineId" column="medicine_id"/>
        <result property="medicineStockId" column="medicine_stock_id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
    </resultMap>

    <resultMap id="MallProductDtoMap" type="cn.zhangchuangla.medicine.common.core.model.dto.MallProductDto">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="categoryId" column="category_id"/>
        <result property="unit" column="unit"/>
        <result property="price" column="price"/>
        <result property="salesVolume" column="sales_volume"/>
        <result property="stock" column="stock"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="deliveryType" column="delivery_type"/>
        <result property="shippingId" column="shipping_id"/>
        <result property="bindType" column="bind_type"/>
        <result property="medicineId" column="medicine_id"/>
        <result property="medicineStockId" column="medicine_stock_id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="categoryName" column="category_name"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,name,category_id,unit,price,sales_volume,
        stock,sort,status,delivery_type,shipping_id,
        bind_type,medicine_id,medicine_stock_id,create_time,update_time,
        create_by,update_by
    </sql>
    <select id="listMallProduct" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM mall_product
        <where>
            <if test="request.id != null">
                AND id = #{request.id}
            </if>
            <if test="request.name != null and request.name != ''">
                AND name LIKE CONCAT('%', #{request.name}, '%')
            </if>
            <if test="request.categoryId != null">
                AND category_id = #{request.categoryId}
            </if>
            <if test="request.status != null">
                AND status = #{request.status}
            </if>
            <if test="request.bindType != null">
                AND bind_type = #{request.bindType}
            </if>
            <if test="request.medicineId != null">
                AND medicine_id = #{request.medicineId}
            </if>
            <if test="request.minPrice != null">
                AND price >= #{request.minPrice}
            </if>
            <if test="request.maxPrice != null">
                AND price &lt;= #{request.maxPrice}
            </if>
        </where>
        ORDER BY sort ASC, create_time DESC
    </select>

    <!-- 查询商品列表（包含分类名称） -->
    <select id="listMallProductWithCategory" resultMap="MallProductDtoMap">
        SELECT
        product.id,
        product.name,
        product.category_id,
        product.unit,
        product.price,
        product.sales_volume,
        product.stock,
        product.sort,
        product.status,
        product.delivery_type,
        product.shipping_id,
        product.bind_type,
        product.medicine_id,
        product.medicine_stock_id,
        product.create_time,
        product.update_time,
        product.create_by,
        product.update_by,
        category.name as category_name
        FROM mall_product product
        LEFT JOIN mall_category category ON product.category_id = category.id
        <where>
            <if test="request.id != null">
                AND product.id = #{request.id}
            </if>
            <if test="request.name != null and request.name != ''">
                AND product.name LIKE CONCAT('%', #{request.name}, '%')
            </if>
            <if test="request.categoryId != null">
                AND product.category_id = #{request.categoryId}
            </if>
            <if test="request.status != null">
                AND product.status = #{request.status}
            </if>
            <if test="request.bindType != null">
                AND product.bind_type = #{request.bindType}
            </if>
            <if test="request.medicineId != null">
                AND product.medicine_id = #{request.medicineId}
            </if>
            <if test="request.minPrice != null">
                AND product.price >= #{request.minPrice}
            </if>
            <if test="request.maxPrice != null">
                AND product.price &lt;= #{request.maxPrice}
            </if>
        </where>
        ORDER BY product.sort ASC, product.create_time DESC
    </select>
</mapper>
