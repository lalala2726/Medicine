<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.zhangchuangla.medicine.ai.gateway.mapper.AdminOrderMapper">

    <resultMap id="BaseResultMap" type="cn.zhangchuangla.medicine.model.entity.MallOrder">
        <id property="id" column="id"/>
        <result property="orderNo" column="order_no"/>
        <result property="userId" column="user_id"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="payAmount" column="pay_amount"/>
        <result property="freightAmount" column="freight_amount"/>
        <result property="payType" column="pay_type"/>
        <result property="orderStatus" column="order_status"/>
        <result property="deliveryType" column="delivery_type"/>
        <result property="addressId" column="address_id"/>
        <result property="receiverName" column="receiver_name"/>
        <result property="receiverPhone" column="receiver_phone"/>
        <result property="receiverDetail" column="receiver_detail"/>
        <result property="note" column="note"/>
        <result property="payExpireTime" column="pay_expire_time"/>
        <result property="refundStatus" column="refund_status"/>
        <result property="refundTime" column="refund_time"/>
        <result property="refundPrice" column="refund_price"/>
        <result property="afterSaleFlag" column="after_sale_flag"/>
        <result property="payTime" column="pay_time"/>
        <result property="paid" column="paid"/>
        <result property="deliverTime" column="deliver_time"/>
        <result property="receiveTime" column="receive_time"/>
        <result property="finishTime" column="finish_time"/>
        <result property="closeReason" column="close_reason"/>
        <result property="closeTime" column="close_time"/>
        <result property="createTime" column="create_time"/>
        <result property="version" column="version"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="remark" column="remark"/>
        <result property="isDeleted" column="is_deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,
        order_no,
        user_id,
        total_amount,
        pay_amount,
        freight_amount,
        pay_type,
        order_status,
        delivery_type,
        address_id,
        receiver_name,
        receiver_phone,
        receiver_detail,
        note,
        pay_expire_time,
        refund_status,
        refund_time,
        refund_price,
        after_sale_flag,
        pay_time,
        paid,
        deliver_time,
        receive_time,
        finish_time,
        close_reason,
        close_time,
        create_time,
        version,
        update_time,
        create_by,
        update_by,
        remark,
        is_deleted
    </sql>

    <select id="listOrderPage" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM mall_order
        <where>
            (is_deleted IS NULL OR is_deleted = 0)
            <if test="query.orderNo != null and query.orderNo != ''">
                AND order_no = #{query.orderNo}
            </if>
            <if test="query.payType != null and query.payType != ''">
                AND pay_type = #{query.payType}
            </if>
            <if test="query.orderStatus != null and query.orderStatus != ''">
                AND order_status = #{query.orderStatus}
            </if>
            <if test="query.deliveryType != null and query.deliveryType != ''">
                AND delivery_type = #{query.deliveryType}
            </if>
            <if test="query.receiverName != null and query.receiverName != ''">
                AND receiver_name LIKE CONCAT('%', #{query.receiverName}, '%')
            </if>
            <if test="query.receiverPhone != null and query.receiverPhone != ''">
                AND receiver_phone LIKE CONCAT('%', #{query.receiverPhone}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="getOrderById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM mall_order
        WHERE (is_deleted IS NULL OR is_deleted = 0)
        AND id = #{id}
    </select>
</mapper>
