<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.zhangchuangla.medicine.ai.gateway.mapper.AdminProductMapper">

    <resultMap id="BaseResultMap" type="cn.zhangchuangla.medicine.model.entity.MallProduct">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="categoryId" column="category_id"/>
        <result property="unit" column="unit"/>
        <result property="price" column="price"/>
        <result property="stock" column="stock"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="deliveryType" column="delivery_type"/>
        <result property="version" column="version"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="isDeleted" column="is_deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,
        name,
        category_id,
        unit,
        price,
        stock,
        sort,
        status,
        delivery_type,
        version,
        create_time,
        update_time,
        create_by,
        update_by,
        is_deleted
    </sql>

    <select id="listProductPage" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM mall_product
        <where>
            (is_deleted IS NULL OR is_deleted = 0)
            <if test="query.id != null">
                AND id = #{query.id}
            </if>
            <if test="query.name != null and query.name != ''">
                AND name LIKE CONCAT('%', #{query.name}, '%')
            </if>
            <if test="query.categoryId != null">
                AND category_id = #{query.categoryId}
            </if>
            <if test="query.status != null">
                AND status = #{query.status}
            </if>
            <if test="query.minPrice != null">
                AND price &gt;= #{query.minPrice}
            </if>
            <if test="query.maxPrice != null">
                AND price &lt;= #{query.maxPrice}
            </if>
        </where>
        ORDER BY sort ASC, create_time DESC
    </select>

    <select id="getProductById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM mall_product
        WHERE (is_deleted IS NULL OR is_deleted = 0)
        AND id = #{id}
    </select>
</mapper>
