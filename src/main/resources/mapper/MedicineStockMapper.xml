<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.zhangchuangla.medicine.mapper.MedicineStockMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="cn.zhangchuangla.medicine.model.entity.MedicineStock">
        <id property="id" column="id"/>
        <result property="medicineId" column="medicine_id"/>
        <result property="batchNo" column="batch_no"/>
        <result property="quantity" column="quantity"/>
        <result property="expiryDate" column="expiry_date"/>
        <result property="warehouse" column="warehouse"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 带药品信息的查询映射结果 -->
    <resultMap id="MedicineStockWithMedicineResultMap" type="cn.zhangchuangla.medicine.model.entity.MedicineStock">
        <id property="id" column="id"/>
        <result property="medicineId" column="medicine_id"/>
        <result property="batchNo" column="batch_no"/>
        <result property="quantity" column="quantity"/>
        <result property="expiryDate" column="expiry_date"/>
        <result property="warehouse" column="warehouse"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <!-- 药品信息 -->
        <result property="medicineId" column="medicine_id"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, medicine_id, batch_no, quantity, expiry_date, warehouse, create_time, update_time
    </sql>

    <!-- 带药品信息的查询结果列 -->
    <sql id="MedicineStock_With_Medicine_Column_List">
        ms.id, ms.medicine_id, ms.batch_no, ms.quantity, ms.expiry_date, ms.warehouse,
        ms.create_time, ms.update_time,
        m.name as medicine_name, m.generic_name, m.specification, m.manufacturer
    </sql>

    <!-- 分页查询药品库存列表 -->
    <select id="listMedicineStock" resultMap="MedicineStockWithMedicineResultMap">
        SELECT
        <include refid="MedicineStock_With_Medicine_Column_List"/>
        FROM medicine_stock ms
        LEFT JOIN medicine m ON ms.medicine_id = m.id
        <where>
            <if test="request.medicineId != null">
                AND ms.medicine_id = #{request.medicineId}
            </if>
            <if test="request.medicineName != null and request.medicineName != ''">
                AND (m.name LIKE CONCAT('%', #{request.medicineName}, '%')
                OR m.generic_name LIKE CONCAT('%', #{request.medicineName}, '%'))
            </if>
            <if test="request.batchNo != null and request.batchNo != ''">
                AND ms.batch_no LIKE CONCAT('%', #{request.batchNo}, '%')
            </if>
            <if test="request.warehouse != null and request.warehouse != ''">
                AND ms.warehouse LIKE CONCAT('%', #{request.warehouse}, '%')
            </if>
            <if test="request.isExpired != null">
                <if test="request.isExpired == true">
                    AND ms.expiry_date &lt; NOW()
                </if>
                <if test="request.isExpired == false">
                    AND ms.expiry_date &gt;= NOW()
                </if>
            </if>
            <if test="request.stockStatus != null and request.stockStatus != ''">
                <if test="request.stockStatus == 'low'">
                    AND ms.quantity &lt; 50
                </if>
                <if test="request.stockStatus == 'normal'">
                    AND ms.quantity &gt;= 50 AND ms.quantity &lt; 200
                </if>
                <if test="request.stockStatus == 'high'">
                    AND ms.quantity &gt;= 200
                </if>
            </if>
        </where>
        ORDER BY ms.create_time DESC
    </select>

</mapper>
